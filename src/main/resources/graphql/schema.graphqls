type Product {
    name: String
    category: String
    price: Int
    stock: Int
}

input ProductFilter{
    name: String
    category: String
    price: Int
    stock: Int
}

type Query {
    filterProducts(filter: ProductFilter): [Product]
}

type Mutation {
    updateStock(name: String!, newStock: Int!): Boolean
    receiveNewShipment(name: String!, receivedQuantity: Int!): Boolean
    addNewProduct(name: String!, category: String!, price: Int!, stock: Int!): Boolean
}