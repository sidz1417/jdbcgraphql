type Product {
    id: ID,
    name: String,
    category: String,
    price: Int,
    stock: Int
}

type Query {
    getProducts: [Product],
    getProductsByCategory(category: String): [Product]
}

type Mutation {
    updateStock(name: String, newStock: Int): Boolean
    receiveNewShipment(name: String, receivedQuantity: Int): Boolean
    addNewProduct(name: String, category: String, price: Int, stock: Int): Boolean
}